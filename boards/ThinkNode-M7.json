      "-D BOARD_HAS_PSRAM",
      "-D ARDUINO_USB_CDC_ON_BOOT=0",
      "-D ARDUINO_USB_MODE=0",
      "-D ARDUINO_RUNNING_CORE=1",
      "-D ARDUINO_EVENT_RUNNING_CORE=0"
    ],
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "flash_mode": "qio",
    "psram_type": "qio_opi",
    "hwids": [["0x303A", "0x1001"]],
    "mcu": "esp32s3",
    "variant": "ELECROW-ThinkNode-M7"
